[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = false

[libraries]
windows.debug.x86_64 = "res://addons/pkmn_client/bin/pkmn_client.dll"
windows.release.x86_64 = "res://addons/pkmn_client/bin/pkmn_client.dll"
linux.debug.x86_64 = "res://addons/pkmn_client/bin/libpkmn_client.so"
linux.release.x86_64 = "res://addons/pkmn_client/bin/libpkmn_client.so"
macos.debug = "res://addons/pkmn_client/bin/libpkmn_client.dylib"
macos.release = "res://addons/pkmn_client/bin/libpkmn_client.dylib"
