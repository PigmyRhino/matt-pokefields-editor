[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/map_inspector.gd" id="1_mapinsp"]

[node name="MapInspector" type="PanelContainer"]
custom_minimum_size = Vector2(300, 0)
script = ExtResource("1_mapinsp")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 8

[node name="Scroll" type="ScrollContainer" parent="Margin"]
layout_mode = 2

[node name="Fields" type="VBoxContainer" parent="Margin/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 6

[node name="MTitle" type="Label" parent="Margin/Scroll/Fields"]
unique_name_in_owner = true
layout_mode = 2
text = "Map"

[node name="MInfo" type="Label" parent="Margin/Scroll/Fields"]
unique_name_in_owner = true
layout_mode = 2
text = ""

[node name="Hint" type="Label" parent="Margin/Scroll/Fields"]
layout_mode = 2
text = "General map data (click empty space to return here)."
autowrap_mode = 2
theme_override_colors/font_color = Color(0.6, 0.65, 0.72, 1)

[node name="Sep" type="HSeparator" parent="Margin/Scroll/Fields"]
layout_mode = 2

[node name="MDark" type="CheckButton" parent="Margin/Scroll/Fields"]
unique_name_in_owner = true
layout_mode = 2
text = "Dark (needs Flash)"
tooltip_text = "Marks this map dark. Purely authored — there's no ROM source, so this toggle is the only way to set it."
